<Window x:Class="FreeFlow.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FreeFlow - Stats File Uploader" 
        Height="620" Width="980"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="FreeFlow"
                       FontSize="22"
                       FontWeight="SemiBold"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>
                <Button Content="Save" Command="{Binding SaveCommand}" Width="110" Margin="0,0,8,0"/>
                <Button Content="Start" Command="{Binding StartCommand}" Width="110" Margin="0,0,8,0"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Width="110"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="Watched file" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding WatchedFilePath}" IsReadOnly="True" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseWatchedFileCommand}" MinWidth="110"/>

                <TextBlock Grid.Column="3" Text="" />

                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Settle (sec)" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding SettleDelaySeconds}" Width="56" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Destinations" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Destinations}"
                              SelectedItem="{Binding SelectedDestination}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding IsEnabled}" Width="45"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="90"/>
                            <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="*"/>
                            <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="70"/>
                            <DataGridTextColumn Header="Remote path" Binding="{Binding RemotePath}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Add" Command="{Binding AddDestinationCommand}" Width="90" Margin="0,0,8,0"/>
                        <Button Content="Edit" Command="{Binding EditDestinationCommand}" Width="90" Margin="0,0,8,0"/>
                        <Button Content="Remove" Command="{Binding RemoveDestinationCommand}" Width="90" Margin="0,0,8,0"/>
                        <Button Content="Test" Command="{Binding TestDestinationCommand}" Width="90"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Activity" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Activity}"/>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   TextWrapping="Wrap"
                   Foreground="#666"
                   Margin="0,12,0,0"
                   Text="MVP note: SFTP and password encryption are not implemented yet. Use FTP/FTPS for now."/>
    </Grid>
</Window>
